---
import ArticleLayout from '../layouts/ArticleLayout.astro';
import CopyBlock from '../components/CopyBlock.astro';

/* ── Modèle de lettre de rétractation ──────────────────── */
const retractationModel = `[Prénom Nom]
[Adresse]
[Code postal – Ville]

À [Ville], le [Date]

[Nom de l'employeur / Raison sociale]
À l'attention de [Nom du responsable RH ou dirigeant]
[Adresse de l'entreprise]

Objet : Rétractation de la convention de rupture conventionnelle
        signée le [date de signature]

Madame, Monsieur,

Par la présente lettre recommandée avec accusé de réception,
je vous notifie ma décision de me rétracter de la convention
de rupture conventionnelle que nous avons signée le [date],
conformément à l'article L1237-13 du Code du travail.

Cette rétractation intervient dans le délai légal de
15 jours calendaires suivant la signature.

En conséquence, mon contrat de travail se poursuit aux
conditions habituelles, sans modification.

Veuillez agréer, Madame, Monsieur, l'expression de mes
salutations distinguées.

[Signature manuscrite]
[Prénom Nom]`;

/* ── Structure ─────────────────────────────────────────── */
const toc = [
  { id: 'definition',   label: "Qu'est-ce que la rupture conventionnelle ?" },
  { id: 'procedure',    label: 'La procédure étape par étape'               },
  { id: 'indemnite',    label: "L'indemnité spécifique"                     },
  { id: 'simulateur',   label: "Simulateur et calcul de l'indemnité"        },
  { id: 'retractation', label: 'Le délai de rétractation'                   },
  { id: 'chomage',      label: 'Rupture conv. et chômage'                   },
  { id: 'faq',          label: 'Questions fréquentes'                       },
];

const summary = [
  "La rupture conventionnelle est un accord amiable entre employeur et salarié pour mettre fin au CDI — elle ouvre droit au chômage contrairement à la démission.",
  "L'indemnité spécifique de rupture conventionnelle ne peut pas être inférieure à l'indemnité légale de licenciement.",
  "Un délai de rétractation de 15 jours calendaires s'applique après signature de la convention — chaque partie peut revenir sur sa décision sans motif.",
];

const faq = [
  {
    question: "L'employeur peut-il refuser une rupture conventionnelle ?",
    answer:   "Oui. La rupture conventionnelle est un accord bilatéral — ni le salarié ni l'employeur ne peut l'imposer à l'autre. L'employeur peut refuser sans avoir à se justifier. Dans ce cas, le salarié ne dispose d'aucun recours pour l'y contraindre. La négociation reste la seule voie : préparez votre demande avec des arguments concrets (coût d'un remplacement, difficultés relationnelles, projet professionnel) pour maximiser vos chances d'obtenir un accord.",
  },
  {
    question: "Peut-on signer une rupture conventionnelle pendant un arrêt maladie ?",
    answer:   "Oui. La rupture conventionnelle est possible pendant un arrêt maladie ordinaire — il n'existe pas d'interdiction légale. Toutefois, le juge vérifie que le consentement du salarié n'a pas été vicié par sa situation de fragilité. Si le salarié est en arrêt pour maladie professionnelle ou accident du travail, les règles sont identiques depuis 2012. Assurez-vous que la décision est libre et éclairée, et faites-vous assister lors de l'entretien si nécessaire.",
  },
  {
    question: "La rupture conventionnelle est-elle possible pendant la période d'essai ?",
    answer:   "Non. Pendant la période d'essai, chaque partie peut rompre librement le contrat selon les règles propres à la période d'essai (délai de prévenance). La rupture conventionnelle est réservée aux CDI en cours d'exécution, hors période d'essai. Après la fin de la période d'essai, elle redevient possible.",
  },
  {
    question: "Combien de temps prend la procédure de bout en bout ?",
    answer:   "La procédure dure au minimum 1 mois entre la première demande et la rupture effective du contrat. Décomposition : entretien(s) préalable(s) → signature de la convention → délai de rétractation de 15 jours calendaires → envoi à la DREETS → instruction de 15 jours ouvrables → homologation → rupture le lendemain ou à la date convenue. En pratique, comptez 5 à 8 semaines selon la rapidité des parties.",
  },
  {
    question: "Peut-on contester une rupture conventionnelle après homologation ?",
    answer:   "Oui, dans un délai de 12 mois à compter de la date d'homologation (article L1237-14 du Code du travail). Les motifs de contestation incluent : vice du consentement (pression, harcèlement, état de vulnérabilité), non-respect de la procédure (absence d'entretien, défaut d'assistance), ou montant de l'indemnité inférieur au minimum légal. En cas de succès, la rupture conventionnelle peut être requalifiée en licenciement sans cause réelle et sérieuse.",
  },
];

const relatedArticles = [
  {
    title:        'Lettre de démission CDI : modèle gratuit',
    href:         '/lettre-de-demission-cdi/',
    category:     'Démission',
    categorySlug: 'demission',
  },
  {
    title:        'Démission et chômage : avez-vous droit aux ARE ?',
    href:         '/demission-chomage/',
    category:     'Démission',
    categorySlug: 'demission',
  },
  {
    title:        'Solde de tout compte : calcul et contestation',
    href:         '/solde-de-tout-compte/',
    category:     'Démission',
    categorySlug: 'demission',
  },
];

const sidebarLinks = [
  { title: "Simulateur indemnité rupture conv.", href: 'https://code.travail.gouv.fr/outils/indemnite-licenciement' },
  { title: 'Lettre demande rupture conv.',       href: '/lettre-rupture-conventionnelle/'                          },
  { title: 'Contester une rupture conv.',        href: '/contester-rupture-conventionnelle/'                       },
