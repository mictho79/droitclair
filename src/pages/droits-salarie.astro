---

<BaseLayout
  title="Droits du salarié en cours de contrat — Guides 2026"
  description="Arrêt maladie, congés payés, période d'essai, heures supplémentaires, mutuelle — tous vos droits en cours de contrat de travail. Guides pratiques mis à jour 2026."
>

  <!-- En-tête de catégorie -->
  <div class="cat-hero">
    <div class="container cat-hero__inner">
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href="/">Accueil</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Droits du salarié</span>
      </nav>
      <h1 class="cat-hero__title">Droits en cours de contrat</h1>
      <p class="cat-hero__desc">
        Tout ce que vous devez savoir sur vos droits pendant l'exécution de votre contrat :
        arrêt maladie, congés payés, heures supplémentaires, période d'essai et mutuelle d'entreprise.
      </p>
      <p class="cat-hero__count">{articles.length} guides disponibles</p>
    </div>
  </div>

  <!-- Grille d'articles -->
  <div class="cat-body">
    <div class="container">
      <div class="cat-grid">
        {articles.map((article) => (
          <ArticleCard {...article} />
        ))}
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .cat-hero {
    background-color: var(--clr-gray);
    border-bottom: 1px solid var(--clr-border);
    padding-block: var(--space-8) var(--space-7);
  }

  .cat-hero__inner {
    max-width: 760px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--clr-text-muted);
    margin-bottom: var(--space-4);
  }

  .breadcrumb a {
    color: var(--clr-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--clr-green);
    text-decoration: underline;
  }

  .cat-hero__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--clr-black);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
  }

  .cat-hero__desc {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--clr-text-muted);
    max-width: 60ch;
    margin-bottom: var(--space-4);
  }

  .cat-hero__count {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--clr-green);
    margin: 0;
  }

  .cat-body {
    padding-block: var(--space-9) var(--space-12);
    background-color: #ffffff;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  @media (max-width: 1024px) {
    .cat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
