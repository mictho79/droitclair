  { id: 'legitime',      label: 'Les démissions légitimes reconnues'                 },
  { id: 'reconversion',  label: 'La démission-reconversion (loi 2018)'               },
  { id: 'reexamen',      label: 'Le réexamen après 4 mois de chômage'               },
  { id: 'cas-pratiques', label: 'Cas pratiques'                                     },
  { id: 'faq',           label: 'Questions fréquentes'                               },
];

const summary = [
  "Une démission volontaire ne donne pas droit à l'ARE (allocation chômage) — sauf si elle est reconnue comme « légitime » par France Travail.",
  "Depuis 2019, la démission-reconversion permet d'accéder aux ARE si vous avez un projet de formation ou de création d'entreprise validé.",
  "Sans motif légitime, vous pouvez demander un réexamen de votre dossier après 4 mois de chômage non indemnisé.",
];

const faq = [
  {
    question: "Combien de temps faut-il attendre avant d'être indemnisé après une démission légitime ?",
    answer:   "Après une démission légitime reconnue, France Travail applique un délai de carence standard (7 jours) et un différé d'indemnisation calculé sur vos indemnités de fin de contrat. Il n'y a pas de délai de carence spécifique lié à la démission elle-même. L'ouverture des droits intervient généralement dans les 2 à 4 semaines suivant l'inscription.",
  },
  {
    question: "Peut-on cumuler ARE et activité partielle après une démission ?",
    answer:   "Non directement. L'ARE est versée après une rupture de contrat, non pendant. Si vous créez une activité indépendante après votre démission et que celle-ci est reconnue comme légitime ou dans le cadre d'une démission-reconversion, vous pouvez cumuler partiellement l'ARE avec des revenus non salariés, dans la limite d'un plafond fixé par France Travail.",
  },
  {
    question: "La démission suite à un harcèlement moral donne-t-elle droit au chômage ?",
    answer:   "Oui, si le harcèlement est établi et que vous pouvez en apporter la preuve (attestations, mails, plainte, etc.). France Travail peut reconnaître une démission pour harcèlement comme légitime. En l'absence de reconnaissance immédiate, vous pourrez demander un réexamen après 4 mois et saisir les Prud'hommes pour faire requalifier votre démission en prise d'acte, ce qui ouvre automatiquement les droits.",
  },
  {
    question: "Quelles pièces fournir pour une démission-reconversion ?",
    answer:   "Vous devez présenter à la commission paritaire interprofessionnelle régionale (CPIR) un dossier comprenant : votre projet professionnel détaillé, un plan de financement si vous créez une entreprise, ou une attestation d'admission à la formation souhaitée. La CPIR dispose de 2 mois pour se prononcer. Sans réponse, la demande est considérée comme rejetée.",
  },
  {
    question: "Que se passe-t-il si France Travail rejette mon réexamen après 4 mois ?",
    answer:   "En cas de rejet, vous ne bénéficiez d'aucune indemnisation. Vous pouvez contester la décision devant la juridiction compétente (tribunal judiciaire) ou tenter de faire requalifier votre démission en licenciement aux Prud'hommes si l'employeur a commis des manquements graves à ses obligations. Il est conseillé de consulter un avocat spécialisé en droit du travail dans ce cas.",
  },
];

const relatedArticles = [
  {
    title:        'Lettre de démission CDI : modèle gratuit',
    href:         '/lettre-de-demission-cdi/',
    category:     'Démission',
    categorySlug: 'demission',
  },
  {
    title:        'Préavis de démission CDI : durée et calcul',
    href:         '/demission/preavis-demission/',
    category:     'Démission',
    categorySlug: 'demission',
  },
  {
    title:        'Rupture conventionnelle : alternative à la démission ?',
    href:         '/rupture-conventionnelle/guide-complet/',
    category:     'Rupture conventionnelle',
    categorySlug: 'rupture-conventionnelle',
  },
];

const sidebarLinks = [
  { title: 'Les cas de démission légitime (liste complète)',          href: '/demission/demission-legitime/'          },
  { title: 'Rupture conventionnelle et chômage',                      href: '/rupture-conventionnelle/chomage/'       },
  { title: 'Simulateur ARE : estimez vos allocations',                href: '/outils/simulateur-are/'                 },
