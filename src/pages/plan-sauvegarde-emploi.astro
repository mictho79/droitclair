<ArticleLayout
  title="Plan de sauvegarde de l'emploi (PSE) : obligations et droits des salariés"
  description="PSE en 2026 : seuils d'obligation (50 salariés / 10 licenciements), contenu obligatoire, validation par la DREETS, droits des salariés et nullité des licenciements sans PSE."
  publishedDate="2026-03-20"
  modifiedDate="2026-03-25"
  category="Licenciement"
  categorySlug="licenciement"
  readingTime={7}
  summary={summary}
  toc={toc}
  faq={faq}
