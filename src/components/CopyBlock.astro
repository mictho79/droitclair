---
interface Props {
  content: string;
  label?: string;
}

const { content, label = 'Modèle à copier' } = Astro.props;
---

<div class="copy-block">
  <div class="copy-block__header">
    <div class="copy-block__label">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2"/>
        <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
      </svg>
      {label}
    </div>
    <button class="copy-block__btn" type="button" aria-label="Copier le modèle dans le presse-papier">
      Copier
    </button>
  </div>
  <pre class="copy-block__pre"><code class="copy-block__code">{content}</code></pre>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.copy-block').forEach((block) => {
    const btn  = block.querySelector<HTMLButtonElement>('.copy-block__btn');
    const code = block.querySelector<HTMLElement>('.copy-block__code');
    if (!btn || !code) return;

    btn.addEventListener('click', async () => {
      const text = code.innerText;
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        // Fallback pour navigateurs sans clipboard API
        const ta = Object.assign(document.createElement('textarea'), {
          value: text,
          style: 'position:fixed;opacity:0',
        });
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      btn.textContent = '✓ Copié !';
      btn.classList.add('is-copied');
      setTimeout(() => {
        btn.textContent = 'Copier';
        btn.classList.remove('is-copied');
      }, 2500);
    });
  });
</script>

<style>
  .copy-block {
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-block: var(--space-6);
    box-shadow: var(--shadow-xs);
  }

  /* En-tête */
  .copy-block__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background-color: #E8EDF2;
    border-bottom: 1px solid var(--clr-border);
  }

  .copy-block__label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--clr-text-muted);
  }

  /* Bouton copier */
  .copy-block__btn {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--clr-primary);
    background: #ffffff;
    border: 1.5px solid currentColor;
    border-radius: var(--radius-sm);
    padding: 0.35em 1em;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background-color var(--duration) var(--ease),
      color            var(--duration) var(--ease),
      border-color     var(--duration) var(--ease);
  }

  .copy-block__btn:hover {
    background-color: var(--clr-primary);
    color: #ffffff;
    border-color: var(--clr-primary);
  }

  .copy-block__btn.is-copied {
    background-color: var(--clr-green);
    color: #ffffff;
    border-color: var(--clr-green);
  }

  /* Corps : police mono */
  .copy-block__pre {
    margin: 0;
    padding: var(--space-5) var(--space-5);
    background-color: var(--clr-gray);
    overflow-x: auto;
  }

  .copy-block__code {
    font-family: 'Menlo', 'Consolas', 'Monaco', 'Courier New', monospace;
    font-size: 0.8125rem;
    line-height: 1.75;
    color: var(--clr-text);
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
