---
// AdSquare.astro — Placeholder 300×250 (slots 1 & 3)
// Remplacer par <ins class="adsbygoogle"> une fois AdSense validé
---

<div class="ad-square" aria-hidden="true">
  <span class="ad-label">Annonce</span>
</div>

<style>
  .ad-square {
    width: 300px;
    height: 250px;
    background-color: #f3f4f6;
    border: 1px dashed #d1d5db;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ad-label {
    font-size: 11px;
    font-weight: 500;
    color: #9ca3af;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
</style>
