---
// ArretMaladieCalculator.astro
// Art. L1226-1 Code du travail + ANI cadres — valeurs indicatives
// Aucune dépendance externe
---

<div class="amc-wrapper" id="arret-calculator">

  <h3 class="amc-title">Estimez votre maintien de salaire</h3>

  <form class="amc-form" id="amc-form" novalidate>

    <!-- Statut -->
    <fieldset class="amc-fieldset">
      <legend class="amc-label">Votre statut</legend>
      <div class="amc-radio-group">
        <label class="amc-radio">
          <input type="radio" name="statut" value="non-cadre" checked />
          <span>Non-cadre</span>
        </label>
        <label class="amc-radio">
          <input type="radio" name="statut" value="cadre" />
          <span>Cadre</span>
        </label>
      </div>
    </fieldset>

    <!-- Ancienneté -->
    <div class="amc-field">
      <label class="amc-label" for="amc-anciennete">Ancienneté dans l'entreprise</label>
      <select class="amc-select" id="amc-anciennete" name="anciennete">
        <option value="">— Sélectionner —</option>
        <option value="moins1an">Moins d'1 an</option>
        <option value="1a5ans">1 à 5 ans</option>
        <option value="5a10ans">5 à 10 ans</option>
        <option value="plus10ans">Plus de 10 ans</option>
      </select>
    </div>

    <!-- Salaire -->
    <div class="amc-field">
      <label class="amc-label" for="amc-salaire">Salaire brut mensuel</label>
      <div class="amc-input-wrap">
        <input class="amc-input" type="number" id="amc-salaire" name="salaire"
               min="0" step="1" placeholder="2 500" />
        <span class="amc-unit">€</span>
      </div>
    </div>

    <!-- Durée arrêt -->
    <div class="amc-field">
      <label class="amc-label" for="amc-duree">Durée de l'arrêt</label>
      <div class="amc-input-wrap amc-input-wrap--sm">
        <input class="amc-input" type="number" id="amc-duree" name="duree"
               min="1" max="365" step="1" placeholder="30" />
        <span class="amc-unit">jours</span>
      </div>
    </div>

    <button class="amc-btn" type="submit">Calculer le maintien de salaire</button>

  </form>

  <!-- Résultat -->
  <div class="amc-result" id="amc-result" hidden>
    <div class="amc-periods" id="amc-periods"></div>
    <div class="amc-total-block">
      <span class="amc-total-label">Estimation totale sur la période</span>
      <span class="amc-total-amount" id="amc-total"></span>
    </div>
    <p class="amc-result__warning">
      ⚠️ Ces montants sont <strong>indicatifs</strong>. Ils ne tiennent pas compte des
      spécificités de votre convention collective (qui peut être plus favorable), du plafond
      SS exact ni des jours ouvrables/calendaires selon votre convention.
      Vérifiez votre contrat de travail et renseignez-vous auprès de votre RH ou de la CPAM.
    </p>
  </div>

  <!-- Moins d'1 an non-cadre -->
  <div class="amc-result amc-result--info" id="amc-no-right" hidden>
    <p>
      <strong>Pas de maintien légal obligatoire.</strong> Avec moins d'1 an d'ancienneté,
      le Code du travail n'impose pas à l'employeur de maintenir votre salaire.
      Votre convention collective peut néanmoins prévoir un maintien dès le 1er jour —
      vérifiez votre CCN (code IDCC sur votre fiche de paie).
    </p>
  </div>

</div>

<style>
  .amc-wrapper {
    background: #fff;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    padding: var(--space-6);
    margin-block: var(--space-7);
  }

  .amc-title {
    font-family: var(--font-display);
    font-size: var(--text-lg, 1.125rem);
    font-weight: 700;
    color: var(--clr-black);
    margin: 0 0 var(--space-5);
  }

  .amc-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .amc-field { display: flex; flex-direction: column; gap: var(--space-2); }

  .amc-label {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--clr-black);
  }

  .amc-fieldset { border: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }

  .amc-radio-group { display: flex; flex-wrap: wrap; gap: var(--space-2) var(--space-3); margin-top: var(--space-2); }

  .amc-radio {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    font-size: var(--text-base);
    color: var(--clr-text);
    padding: var(--space-2) var(--space-4);
    border: 1.5px solid var(--clr-border);
    border-radius: var(--radius);
    background: #fff;
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
    user-select: none;
  }

  .amc-radio input[type="radio"] { display: none; }

  .amc-radio:has(input:checked) {
    border-color: var(--clr-primary);
    background: var(--clr-green-light);
    color: var(--clr-primary-dark);
    font-weight: 600;
  }

  .amc-radio:hover { border-color: var(--clr-primary); }

  .amc-select, .amc-input {
    padding: var(--space-2) var(--space-3);
    border: 1.5px solid var(--clr-border);
    border-radius: var(--radius);
    font-size: var(--text-base);
    color: var(--clr-text);
    background: #fff;
    transition: border-color var(--duration) var(--ease);
  }

  .amc-select { max-width: 280px; }

  .amc-select:focus, .amc-input:focus { outline: none; border-color: var(--clr-primary); }

  .amc-input-wrap { display: flex; align-items: center; gap: var(--space-2); max-width: 200px; }
  .amc-input-wrap--sm { max-width: 140px; }
  .amc-input { width: 100%; }

  .amc-unit { font-size: var(--text-sm, 0.875rem); color: var(--clr-text-muted); white-space: nowrap; }

  .amc-btn {
    align-self: flex-start;
    background: var(--clr-primary);
    color: #fff;
    font-size: var(--text-base);
    font-weight: 600;
    padding: var(--space-3) var(--space-5);
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition: background var(--duration) var(--ease);
  }

  .amc-btn:hover { background: var(--clr-primary-dark); }

  /* Résultat */
  .amc-result {
    margin-top: var(--space-5);
    border-top: 1px solid var(--clr-border-subtle);
    padding-top: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .amc-result--info {
    background: #EFF6FF;
    border: 1px solid #BFDBFE;
    border-radius: var(--radius);
    padding: var(--space-4);
    margin-top: var(--space-5);
  }

  .amc-result--info p {
    margin: 0;
    font-size: var(--text-base);
    color: #1E40AF;
    line-height: var(--leading-relaxed, 1.6);
  }

  /* Périodes */
  .amc-periods { display: flex; flex-direction: column; gap: var(--space-2); }

  .amc-period-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius);
    background: #F8FAFC;
    border: 1px solid var(--clr-border-subtle);
    font-size: var(--text-sm, 0.875rem);
  }

  .amc-period-row--carence { background: #FEF2F2; border-color: #FECACA; }
  .amc-period-row--normal { background: var(--clr-green-light); border-color: rgba(29,158,117,0.2); }

  .amc-period-label { color: var(--clr-text); font-weight: 500; }
  .amc-period-amount { font-weight: 700; color: var(--clr-black); white-space: nowrap; }
  .amc-period-row--carence .amc-period-amount { color: #DC2626; }
  .amc-period-row--normal .amc-period-amount { color: var(--clr-primary-dark); }

  /* Total */
  .amc-total-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--clr-green-light);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-5);
    border: 1px solid rgba(29,158,117,0.2);
  }

  .amc-total-label { font-size: var(--text-sm, 0.875rem); font-weight: 700; color: var(--clr-primary-dark); text-transform: uppercase; letter-spacing: 0.04em; }

  .amc-total-amount {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--clr-primary-dark);
  }

  .amc-result__warning {
    font-size: var(--text-sm, 0.875rem);
    color: var(--clr-text-muted);
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: #FFFBEB;
    border-left: 3px solid #F59E0B;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  @media (max-width: 600px) {
    .amc-wrapper { padding: var(--space-4); }
    .amc-input-wrap { max-width: 100%; }
    .amc-select { max-width: 100%; }
    .amc-total-block { flex-direction: column; align-items: flex-start; gap: var(--space-2); }
    .amc-period-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('amc-form') as HTMLFormElement;
  const resultBox = document.getElementById('amc-result') as HTMLDivElement;
  const noRightBox = document.getElementById('amc-no-right') as HTMLDivElement;
  const periodsEl = document.getElementById('amc-periods') as HTMLDivElement;
  const totalEl = document.getElementById('amc-total') as HTMLSpanElement;

  const SMIC_BRUT_MENSUEL = 1801.80; // 2025

  function fmt(n: number): string {
    return n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
  }

  interface Palier { debut: number; fin: number; tauxEmployeur: number; label: string; }

  function getPaliers(statut: string, anciennete: string): Palier[] | null {
    if (statut === 'cadre') {
      if (anciennete === 'moins1an') return null;
      // ANI cadres : 90 jours à 90%
      return [{ debut: 4, fin: 93, tauxEmployeur: 0.90, label: '90 jours à 90 %' }];
    }

    // Non-cadre
    if (anciennete === 'moins1an') return null;

    const jours = anciennete === '1a5ans' ? 30 : anciennete === '5a10ans' ? 40 : 50;

    return [
      { debut: 4, fin: 3 + jours,        tauxEmployeur: 0.90,      label: `${jours} jours à 90 %` },
      { debut: 4 + jours, fin: 3 + jours * 2, tauxEmployeur: 2/3,  label: `${jours} jours à 66,66 %` },
    ];
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const statut = data.get('statut') as string;
    const anciennete = data.get('anciennete') as string;
    const salaire = parseFloat(data.get('salaire') as string);
    const duree = parseInt(data.get('duree') as string) || 0;

    if (!anciennete || !salaire || salaire <= 0 || duree <= 0) return;

    const paliers = getPaliers(statut, anciennete);

    if (!paliers) {
      resultBox.hidden = true;
      noRightBox.hidden = false;
      return;
    }

    // Salaire journalier brut
    const salaireJour = salaire / 30;

    // IJSS journalières ≈ 50% du salaire journalier de base, plafonné à 1.8 SMIC
    const baseIJSS = Math.min(salaire, SMIC_BRUT_MENSUEL * 1.8) / 30;
    const ijssJour = baseIJSS * 0.50;

    const rows: HTMLElement[] = [];
    let totalBrut = 0;

    // Jours 1-3 : carence (ni IJSS, ni maintien)
    const joursCarence = Math.min(3, duree);
    const montantCarence = salaireJour * joursCarence;
    totalBrut += montantCarence;
    const rowCarence = document.createElement('div');
    rowCarence.className = 'amc-period-row amc-period-row--carence';
    rowCarence.innerHTML = `
      <span class="amc-period-label">Jours 1–${joursCarence} (carence Sécu) — pas d'IJSS, maintien selon CCN</span>
      <span class="amc-period-amount">${fmt(montantCarence)} brut estimé</span>
    `;
    rows.push(rowCarence);

    // Périodes de maintien
    for (const palier of paliers) {
      const debut = Math.max(palier.debut, 1);
      const fin = Math.min(palier.fin, duree);
      if (debut > duree) break;
      const nbJours = fin - debut + 1;
      if (nbJours <= 0) continue;

      // Maintien brut = (taux × salaireJour) — déduire IJSS que l'employeur perçoit en subrogation
      const maintienBrut = palier.tauxEmployeur * salaireJour * nbJours;
      const ijssTotal = ijssJour * nbJours;
      const complementEmployeur = Math.max(0, maintienBrut - ijssTotal);
      const netEstime = maintienBrut; // côté salarié : il touche bien tauxEmployeur × salaire
      totalBrut += maintienBrut;

      const row = document.createElement('div');
      row.className = 'amc-period-row amc-period-row--normal';
      row.innerHTML = `
        <span class="amc-period-label">Jours ${debut}–${fin} (${nbJours} j.) — ${palier.label} · IJSS ≈ ${fmt(ijssTotal)} + complément ≈ ${fmt(complementEmployeur)}</span>
        <span class="amc-period-amount">≈ ${fmt(maintienBrut)} brut</span>
      `;
      rows.push(row);
    }

    periodsEl.innerHTML = '';
    rows.forEach(r => periodsEl.appendChild(r));
    totalEl.textContent = `≈ ${fmt(totalBrut)} brut`;

    resultBox.hidden = false;
    noRightBox.hidden = true;
    resultBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
