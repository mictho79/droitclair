---
// AdBanner.astro — Placeholder 728×90 desktop / 320×50 mobile (slot 2)
// Remplacer par <ins class="adsbygoogle"> une fois AdSense validé
---

<div class="ad-banner" aria-hidden="true">
  <span class="ad-label">Annonce</span>
</div>

<style>
  .ad-banner {
    width: 728px;
    height: 90px;
    max-width: 100%;
    background-color: #f3f4f6;
    border: 1px dashed #d1d5db;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-inline: auto;
  }

  .ad-label {
    font-size: 11px;
    font-weight: 500;
    color: #9ca3af;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .ad-banner {
      width: 320px;
      height: 50px;
    }
  }
</style>
