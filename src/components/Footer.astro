---
const year = new Date().getFullYear();

const columns = [
  {
    heading: 'Démission',
    href: '/demission/',
    links: [
      { label: 'Lettre de démission',        href: '/lettre-de-demission-cdi/' },
      { label: 'Préavis de démission',        href: '/preavis-demission/'       },
      { label: 'Démission pour faute de l\'employeur', href: '/demission-faute-employeur/' },
      { label: 'Solde de tout compte',        href: '/solde-de-tout-compte/'    },
      { label: 'Démission et chômage',        href: '/demission-chomage/'       },
    ],
  },
  {
    heading: 'Licenciement',
    href: '/licenciement/',
    links: [
      { label: 'Licenciement économique',     href: '/licenciement-economique/'    },
      { label: 'Licenciement pour faute',     href: '/licenciement-faute-grave/'   },
      { label: 'Indemnité légale',            href: '/indemnite-licenciement/'     },
      { label: 'Contester son licenciement',  href: '/contester-licenciement/'     },
      { label: 'Licenciement pour inaptitude', href: '/licenciement-pour-inaptitude/' },
    ],
  },
  {
    heading: 'Droits du salarié',
    href: '/droits-salarie/',
    links: [
      { label: 'Arrêt maladie et salaire',     href: '/arret-maladie-salaire/'   },
      { label: 'Congés payés',                 href: '/conges-payes-calcul/'     },
      { label: 'Heures supplémentaires',       href: '/heures-supplementaires/'  },
      { label: 'Mutuelle obligatoire',         href: '/mutuelle-obligatoire/'    },
      { label: 'Période d\'essai',             href: '/periode-essai/'           },
    ],
  },
  {
    heading: 'Logement',
    href: '/logement/',
    links: [
      { label: 'Préavis de location',         href: '/preavis-location/' },
      { label: 'Caution locative',            href: '/caution-locative/' },
      { label: 'État des lieux',              href: '/etat-des-lieux/'   },
      { label: 'Résiliation de bail',         href: '/resiliation-bail/' },
      { label: 'Dépôt de garantie',           href: '/depot-de-garantie/' },
    ],
  },
];
---

<footer class="site-footer" role="contentinfo">

  <!-- ── Corps du footer ──────────────────────────────── -->
  <div class="site-footer__body">
    <div class="container site-footer__grid">

      <!-- Colonne brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="DroitClair — retour à l'accueil">
          <svg
            width="24" height="24"
            viewBox="0 0 26 26"
            fill="none"
            aria-hidden="true"
            focusable="false"
          >
            <circle cx="13" cy="13" r="13" fill="#1D9E75"/>
            <rect x="12.1" y="7" width="1.8" height="11" rx="0.9" fill="white"/>
            <rect x="8.5" y="17.5" width="9" height="1.8" rx="0.9" fill="white"/>
            <rect x="6" y="9.6" width="14" height="1.5" rx="0.75" fill="white"/>
            <path d="M7 11.1 Q7 14.2 10 14.2 Q13 14.2 13 11.1" stroke="white" stroke-width="1.4" fill="none" stroke-linecap="round"/>
            <path d="M13 11.1 Q13 14.8 16 14.8 Q19 14.8 19 11.1" stroke="white" stroke-width="1.4" fill="none" stroke-linecap="round"/>
          </svg>
          <span class="footer-logo__wordmark">
            Droit<span class="footer-logo__accent">Clair</span>
          </span>
        </a>

        <p class="footer-brand__tagline">
          Guides pratiques pour salariés
        </p>

        <p class="footer-brand__desc">
          Des réponses claires et à jour sur vos droits en droit du travail et en droit locatif.
        </p>
      </div>

      <!-- Colonnes de liens -->
      <nav class="footer-nav" aria-label="Navigation thématique du pied de page">
        {columns.map(({ heading, href, links }) => (
          <div class="footer-col">
            <h3 class="footer-col__heading">
              <a href={href} class="footer-col__heading-link">{heading}</a>
            </h3>
            <ul role="list" class="footer-col__list">
              {links.map(({ label, href: linkHref }) => (
                <li>
                  <a href={linkHref} class="footer-col__link">{label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

    </div>
  </div>

  <!-- ── Pied de footer ────────────────────────────────── -->
  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-inner">

      <p class="footer-legal">
        <span class="footer-legal__copy">© {year} DroitClair.</span>
        <span class="footer-legal__disclaimer">
          Les informations publiées sont fournies à titre indicatif et ne constituent pas un conseil juridique.
        </span>
      </p>

      <nav class="footer-meta-nav" aria-label="Liens légaux">
        <a href="/mentions-legales/">Mentions légales</a>
        <span aria-hidden="true">·</span>
        <a href="/confidentialite/">Confidentialité</a>
        <span aria-hidden="true">·</span>
        <a href="/contact/">Contact</a>
      </nav>

    </div>
  </div>

</footer>

<style>
  /* ── Fond & layout global ──────────────────────────────────── */
  .site-footer {
    background-color: var(--clr-black);
    color: #8A99A8;
    margin-top: auto;
  }

  /* ── Corps ─────────────────────────────────────────────────── */
  .site-footer__body {
    padding-block: var(--space-9) var(--space-8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  /* ── Brand ─────────────────────────────────────────────────── */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    align-self: flex-start;
  }

  .footer-logo__wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    color: #ffffff;
    line-height: 1;
  }

  .footer-logo__accent {
    color: var(--clr-green);
  }

  .footer-brand__tagline {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 600;
    color: #ffffff;
    line-height: var(--leading-snug);
    max-width: 22ch;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .footer-brand__desc {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: #6B7A8A;
    max-width: 30ch;
    margin: 0;
  }

  /* ── Nav colonnes ───────────────────────────────────────────── */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-7);
  }

  .footer-col__heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: #ffffff;
    margin-bottom: var(--space-4);
  }

  .footer-col__heading-link {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .footer-col__heading-link:hover {
    color: var(--clr-green);
  }

  .footer-col__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-col__link {
    font-size: var(--text-sm);
    color: #6B7A8A;
    text-decoration: none;
    line-height: var(--leading-snug);
    transition: color var(--duration) var(--ease);
    /* Soulignement au hover uniquement */
  }

  .footer-col__link:hover {
    color: #C8D3DC;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(200, 211, 220, 0.35);
  }

  /* ── Pied de footer ─────────────────────────────────────────── */
  .site-footer__bottom {
    padding-block: var(--space-4) var(--space-5);
  }

  .site-footer__bottom-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .footer-legal {
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed);
    color: #4A5568;
    margin: 0;
    max-width: 60ch;
  }

  .footer-legal__copy {
    font-weight: 600;
    color: #5A6A7A;
    margin-right: var(--space-2);
  }

  .footer-legal__disclaimer {
    font-style: italic;
  }

  .footer-meta-nav {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .footer-meta-nav a {
    font-size: var(--text-xs);
    color: #4A5568;
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .footer-meta-nav a:hover {
    color: #8A99A8;
  }

  .footer-meta-nav span {
    color: #2D3748;
    font-size: var(--text-xs);
  }

  /* ── Responsive 1024px ──────────────────────────────────────── */
  @media (max-width: 1024px) {
    .site-footer__grid {
      grid-template-columns: 220px 1fr;
      gap: var(--space-8);
    }

    .footer-nav {
      gap: var(--space-5);
    }
  }

  /* ── Responsive 768px ───────────────────────────────────────── */
  @media (max-width: 768px) {
    .site-footer__body {
      padding-block: var(--space-7) var(--space-6);
    }

    .site-footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }

    .footer-brand__tagline,
    .footer-brand__desc {
      max-width: 100%;
    }

    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6) var(--space-5);
    }

    .site-footer__bottom-inner {
      flex-direction: column;
      gap: var(--space-3);
    }

    .footer-meta-nav {
      white-space: normal;
      flex-wrap: wrap;
    }
  }

  /* ── Responsive 480px ───────────────────────────────────────── */
  @media (max-width: 480px) {
    .footer-nav {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .footer-col__heading {
      margin-bottom: var(--space-3);
    }
  }
</style>
