---
import BaseLayout from './BaseLayout.astro';

interface TocItem       { id: string; label: string }
interface FaqItem       { question: string; answer: string }
interface RelatedItem   { title: string; href: string; category: string; categorySlug?: string }
interface SidebarLink   { title: string; href: string }

interface Props {
  title: string;
  description: string;
  publishedDate: string;
  modifiedDate?: string;
  author?: string;
  category: string;
  categorySlug: string;
  readingTime?: number;
  canonical?: string;
  ogImage?: string;
  /** 3 bullet points pour l'encadré "En résumé" */
  summary: string[];
  /** Entrées de la table des matières (id = ancre HTML) */
  toc: TocItem[];
  /** 5 questions-réponses pour la section FAQ */
  faq: FaqItem[];
  /** Cards "Articles liés" en bas de contenu */
  relatedArticles: RelatedItem[];
  /** Liens dans la sidebar droite */
  sidebarLinks: SidebarLink[];
}

const {
  title,
  description,
  publishedDate,
  modifiedDate,
  author       = 'Équipe DroitClair',
  category,
  categorySlug,
  readingTime,
  canonical,
  ogImage,
  summary,
  toc,
  faq,
  relatedArticles,
  sidebarLinks,
} = Astro.props;

const siteUrl      = import.meta.env.SITE ?? 'https://droitclair.fr';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;

/* ── Mois de mise à jour (ex. "mars 2026") ── */
const updatedLabel = new Date(modifiedDate ?? publishedDate)
  .toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });

/* ── JSON-LD : Article ── */
const schemaArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'DroitClair',
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
  },
  datePublished: publishedDate,
  dateModified:  modifiedDate ?? publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  ...(ogImage ? { image: new URL(ogImage, siteUrl).href } : {}),
};

/* ── JSON-LD : FAQPage ── */
const schemaFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

/* ── JSON-LD : BreadcrumbList ── */
const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil',   item: `${siteUrl}/`               },
    { '@type': 'ListItem', position: 2, name: category,    item: `${siteUrl}/${categorySlug}/` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  publishedDate={publishedDate}
  modifiedDate={modifiedDate}
>
  <!-- JSON-LD dans le <head> -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaArticle)}   />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)}       />
    <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)}/>
  </Fragment>

  <div class="al-page">

    <!-- ── Fil d'Ariane ──────────────────────────────────── -->
    <div class="al-breadcrumb-bar">
      <div class="container">
        <nav aria-label="Fil d'Ariane">
          <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="/" itemprop="item"><span itemprop="name">Accueil</span></a>
              <meta itemprop="position" content="1" />
            </li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href={`/${categorySlug}/`} itemprop="item">
                <span itemprop="name">{category}</span>
              </a>
              <meta itemprop="position" content="2" />
            </li>
            <li aria-current="page" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <span itemprop="name">{title}</span>
              <meta itemprop="position" content="3" />
            </li>
          </ol>
        </nav>
      </div>
    </div>

    <!-- ── Header article ────────────────────────────────── -->
    <header class="al-header">
      <div class="container">
        <div class="al-header__inner">
          <div class="al-header__badges">
            <span class="badge-green al-badge-update">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/>
              </svg>
              Mis à jour {updatedLabel}
            </span>
            {readingTime && (
              <span class="badge-gray">
                {readingTime} min de lecture
              </span>
            )}
          </div>

          <h1 class="al-title">{title}</h1>
          <p class="al-lead">{description}</p>
        </div>
      </div>
    </header>

    <!-- ── Corps : 3 colonnes ────────────────────────────── -->
    <div class="al-body">
      <div class="al-columns">

        <!-- ── Colonne gauche : Table des matières ── -->
        <aside class="al-toc" aria-label="Table des matières">
          <div class="toc-box">
            <p class="toc-box__heading">Dans cet article</p>
            <ol class="toc-list" role="list">
              {toc.map(({ id, label }) => (
                <li>
                  <a href={`#${id}`} class="toc-link" data-toc-id={id}>{label}</a>
                </li>
              ))}
            </ol>
          </div>
        </aside>

        <!-- ── Colonne centrale : contenu ── -->
        <div class="al-main">

          <!-- Encadré "En résumé" -->
          <div class="summary-box" aria-label="En résumé">
            <div class="summary-box__header">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 16v-4M12 8h.01"/>
              </svg>
              <span>En résumé</span>
            </div>
            <ul class="summary-box__list">
              {summary.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </div>

          <!-- Prose injectée par la page -->
          <div class="prose al-prose">
            <slot />
          </div>

          <!-- ── FAQ ── -->
          <section class="al-faq" aria-labelledby="faq-heading">
            <h2 class="al-faq__title" id="faq">Questions fréquentes</h2>

            <div class="faq-list">
              {faq.map(({ question, answer }, i) => (
                <details class="faq-item" {...(i === 0 ? { open: true } : {})}>
                  <summary class="faq-question">
                    <span>{question}</span>
                    <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                      <path d="M6 9l6 6 6-6"/>
                    </svg>
                  </summary>
                  <div class="faq-answer prose">
                    <p set:html={answer} />
                  </div>
                </details>
              ))}
            </div>
          </section>

          <!-- ── Articles liés ── -->
          <section class="al-related" aria-labelledby="related-heading">
            <h2 class="al-related__title" id="related-heading">Articles liés</h2>
            <div class="related-grid">
              {relatedArticles.map(({ title: t, href, category: cat, categorySlug: catSlug }) => (
                <a href={href} class="related-card">
                  <span class={`related-card__badge badge-green`}>{cat}</span>
                  <p class="related-card__title">{t}</p>
                  <span class="related-card__arrow" aria-hidden="true">→</span>
                </a>
              ))}
            </div>
          </section>

        </div>

        <!-- ── Colonne droite : Sidebar ── -->
        <aside class="al-sidebar" aria-label="Articles suggérés">
          <div class="sidebar-box">
            <p class="sidebar-box__heading">Ces articles peuvent vous aider</p>
            <ul class="sidebar-links" role="list">
              {sidebarLinks.map(({ title: t, href }) => (
                <li>
                  <a href={href} class="sidebar-link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                      <path d="M5 12h14M13 6l6 6-6 6"/>
                    </svg>
                    {t}
                  </a>
                </li>
              ))}
            </ul>
            <!-- Espace publicitaire réservé -->
            <div class="sidebar-ad-slot" aria-hidden="true"></div>
          </div>
        </aside>

      </div>
    </div>
  </div>

</BaseLayout>

<!-- TOC active state via IntersectionObserver -->
<script>
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-id]');
  if (tocLinks.length > 0 && 'IntersectionObserver' in window) {
    const ids     = Array.from(tocLinks).map((l) => l.dataset.tocId!);
    const targets = ids.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach((l) => l.classList.remove('is-active'));
            const link = document.querySelector<HTMLAnchorElement>(`[data-toc-id="${entry.target.id}"]`);
            link?.classList.add('is-active');
            break;
          }
        }
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    targets.forEach((t) => observer.observe(t));
  }
</script>

<style>
/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   FIL D'ARIANE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.al-breadcrumb-bar {
  border-bottom: 1px solid var(--clr-border-subtle);
  background: #ffffff;
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   HEADER ARTICLE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.al-header {
  background-color: var(--clr-gray);
  border-bottom: 1px solid var(--clr-border);
  padding-block: var(--space-7) var(--space-6);
}

.al-header__inner {
  max-width: var(--content-width);
}

.al-header__badges {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
}

.al-badge-update {
  display: inline-flex;
  align-items: center;
  gap: 0.4em;
}

.al-title {
  font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  font-weight: 800;
  letter-spacing: var(--tracking-tight);
  line-height: var(--leading-snug);
  color: var(--clr-black);
  margin-bottom: var(--space-3);
}

.al-lead {
  font-size: var(--text-md);
  color: var(--clr-text-muted);
  line-height: var(--leading-relaxed);
  max-width: 60ch;
  margin: 0;
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   GRILLE 3 COLONNES
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.al-body {
  padding-block: var(--space-7) var(--space-9);
}

.al-columns {
  display: grid;
  grid-template-columns: 210px minmax(0, 1fr) 210px;
  gap: var(--space-7);
  max-width: 1220px;
  margin-inline: auto;
  padding-inline: var(--padding-x);
  align-items: start;
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   TABLE DES MATIÈRES (gauche)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.al-toc {
  position: sticky;
  top: 84px; /* 68px header + 16px buffer */
}

.toc-box {
  background: #ffffff;
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-4);
  box-shadow: var(--shadow-xs);
}

.toc-box__heading {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  color: var(--clr-text-faint);
  margin-bottom: var(--space-3);
}

.toc-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.toc-link {
  display: block;
  font-size: var(--text-sm);
  color: var(--clr-text-muted);
  text-decoration: none;
  padding: 0.4em 0.6em;
  border-left: 2px solid var(--clr-border-subtle);
  line-height: var(--leading-snug);
  transition:
    color        var(--duration) var(--ease),
    border-color var(--duration) var(--ease),
    background   var(--duration) var(--ease);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}

.toc-link:hover {
  color: var(--clr-green);
  border-color: var(--clr-green);
  background: var(--clr-green-light);
}

.toc-link.is-active {
  color: var(--clr-green);
  border-color: var(--clr-green);
  font-weight: 600;
  background: var(--clr-green-light);
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   ENCADRÉ EN RÉSUMÉ
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.summary-box {
  background-color: var(--clr-green-light);
  border: 1.5px solid rgba(29, 158, 117, 0.25);
  border-radius: var(--radius-md);
  padding: var(--space-5);
  margin-bottom: var(--space-7);
}

.summary-box__header {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-display);
  font-size: var(--text-md);
  font-weight: 700;
  color: var(--clr-primary-dark);
  margin-bottom: var(--space-4);
}

.summary-box__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  padding-left: var(--space-4);
  margin: 0;
}

.summary-box__list li {
  font-size: var(--text-sm);
  line-height: var(--leading-relaxed);
  color: var(--clr-primary-dark);
}

.summary-box__list li::marker {
  color: var(--clr-green);
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   PROSE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.al-prose {
  max-width: var(--content-width);
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   FAQ
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.al-faq {
  margin-top: var(--space-8);
  max-width: var(--content-width);
}

.al-faq__title {
  font-size: var(--text-xl);
  font-weight: 700;
  letter-spacing: var(--tracking-tight);
  margin-bottom: var(--space-5);
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.faq-item {
  border: 1px solid var(--clr-border);
  border-radius: var(--radius);
  overflow: hidden;
  background: #ffffff;
}

.faq-item[open] {
  border-color: rgba(29, 158, 117, 0.3);
}

.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
  padding: var(--space-4) var(--space-5);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--clr-text);
  cursor: pointer;
  list-style: none;
  user-select: none;
  transition: background var(--duration) var(--ease);
}

.faq-question::-webkit-details-marker { display: none; }

.faq-question:hover {
  background: var(--clr-gray);
}

.faq-item[open] .faq-question {
  background: var(--clr-green-light);
  color: var(--clr-primary-dark);
}

.faq-chevron {
  flex-shrink: 0;
  transition: transform var(--duration) var(--ease);
}

.faq-item[open] .faq-chevron {
  transform: rotate(180deg);
}

.faq-answer {
  padding: var(--space-4) var(--space-5);
  border-top: 1px solid var(--clr-border-subtle);
  font-size: var(--text-sm);
  line-height: var(--leading-relaxed);
  color: var(--clr-text-muted);
}

.faq-answer p { margin: 0; }

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   ARTICLES LIÉS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.al-related {
  margin-top: var(--space-8);
  max-width: var(--content-width);
}

.al-related__title {
  font-size: var(--text-xl);
  font-weight: 700;
  letter-spacing: var(--tracking-tight);
  margin-bottom: var(--space-5);
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: var(--space-4);
}

.related-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding: var(--space-4);
  background: #ffffff;
  border: 1px solid var(--clr-border);
  border-radius: var(--radius);
  text-decoration: none;
  color: var(--clr-text);
  box-shadow: var(--shadow-xs);
  transition:
    border-color var(--duration) var(--ease),
    box-shadow   var(--duration) var(--ease),
    transform    var(--duration) var(--ease);
}

.related-card:hover {
  border-color: var(--clr-green);
  box-shadow: var(--shadow-sm);
  transform: translateY(-2px);
}

.related-card__badge {
  align-self: flex-start;
}

.related-card__title {
  font-size: var(--text-sm);
  font-weight: 600;
  line-height: var(--leading-snug);
  flex: 1;
  margin: 0;
  color: var(--clr-text);
}

.related-card:hover .related-card__title {
  color: var(--clr-green);
}

.related-card__arrow {
  font-size: var(--text-sm);
  color: var(--clr-green);
  align-self: flex-end;
  transition: transform var(--duration) var(--ease);
}

.related-card:hover .related-card__arrow {
  transform: translateX(3px);
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   SIDEBAR DROITE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.al-sidebar {
  position: sticky;
  top: 84px;
}

.sidebar-box {
  background: #ffffff;
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  padding: var(--space-4);
  box-shadow: var(--shadow-xs);
}

.sidebar-box__heading {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  color: var(--clr-text-faint);
  margin-bottom: var(--space-3);
}

.sidebar-links {
  list-style: none;
  display: flex;
  flex-direction: column;
